DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# GitHub OAuth (optional — enables "Continue with GitHub" on the sign-in page).
# Register an OAuth App at https://github.com/settings/developers and set the
# Authorization callback URL to: <PAPERCLIP_PUBLIC_URL>/api/auth/callback/github
# See doc/GITHUB-OAUTH-SETUP.md for full setup instructions.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
